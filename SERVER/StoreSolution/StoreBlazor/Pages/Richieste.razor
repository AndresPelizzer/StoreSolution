@page "/richieste"

<div class="container mt-4">

    @if (loading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Caricamento...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h4 class="mb-0 fw-bold text-secondary">
                        Richieste
                        <span class="badge bg-primary-subtle text-primary rounded-pill ms-2 fs-6">@richieste?.Count</span>
                    </h4>
                    <button class="btn btn-primary btn-sm px-3 rounded-pill shadow-sm" @onclick="() => VaiADettaglioRichieste(0)">
                        <i class="bi bi-plus-lg me-1"></i> Nuova Richiesta
                    </button>
                </div>
            </div>

            <div class="card-body px-4 pb-4">
                <div class="table-responsive rounded-3 border">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-secondary">
                            <tr>
                                <th class="ps-3">Codice</th>
                                <th>Titolo</th>
                                <th>Stato</th>
                                <th>Descrizione</th>
                                <th>Data Richiesta</th>
                                <th>Cliente</th>
                                <th>Area</th>
                                <th>Dipendente</th>
                                <th class="text-center pe-3">Azioni</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (richieste != null && richieste.Any())
                            {
                                @foreach (var richiesta in richieste)
                                {
                                    <tr @onclick="() => VaiADettaglioRichieste(richiesta.Codice)" style="cursor:pointer">
                                        <td class="ps-3 fw-bold text-muted">#@richiesta.Codice</td>
                                        <td class="fw-semibold text-dark">@richiesta.Titolo</td>
                                        <td>
                                            <span class="badge @GetStatoBadgeClass(richiesta.Stato) rounded-pill px-2.5 py-1.5">
                                                @richiesta.Stato
                                            </span>
                                        </td>
                                        <td class="text-muted text-truncate" style="max-width: 200px;">@richiesta.Descrizione</td>
                                        <td class="text-secondary small">@richiesta.DataRichiesta.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@(richiesta.Cliente?.Nome ?? "-")</td>
                                        <td>
                                            <span class="badge bg-light text-dark border rounded-pill">@richiesta.Area?.Descrizione</span>
                                        </td>
                                        <td>
                                            @if (richiesta.Dipendente != null)
                                            {
                                                <span class="text-dark"><i class="bi bi-person me-1 small"></i>@richiesta.Dipendente.Nome</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted italic small">Non assegnato</span>
                                            }
                                        </td>
                                        <td class="text-center pe-3">
                                            <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                    @onclick="() => elimina(richiesta.Codice)"
                                                    @onclick:stopPropagation="true">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-5">
                                        <i class="bi bi-inbox fs-2 d-block mb-2 text-black-50"></i>
                                        Nessuna richiesta presente
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
@page "/dipendenti"

<div class="container mt-5">

    @if (loading == true)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Dipendenti <span class="badge bg-primary ms-1">@dipendenti!.Count</span></h5>
                    <button class="btn btn-primary btn-sm" @onclick="() => VaiADettaglioDipendente(0)">
                        <i class="bi bi-plus-lg"></i> Nuovo
                    </button>
                </div>
                <input class="form-control form-control-sm" placeholder="🔍 Cerca cliente..." @bind="filtro" @bind:event="oninput" />
            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-borderless table-hover table-striped table-sm">
                        <thead>

                            <tr class="table-dark">
                                <th>Codice</th>
                                <th @onclick='() => Ordina("Nome")' style="cursor:pointer">Nome ↕</th>
                                <th @onclick='() => Ordina("Cognome")' style="cursor:pointer">Cognome ↕</th>
                                <th @onclick='() => Ordina("Email")' style="cursor:pointer">Email ↕</th>
                                <th @onclick='() => Ordina("Qualifica")' style="cursor:pointer">Qualifica ↕</th>
                                
                                
                                <th @onclick='() => Ordina("Note")' style="cursor:pointer">Note ↕</th>

                                <th class="text-center">Azioni</th>
                            </tr>

                        </thead>
                        <tbody>

                      
                            @foreach (var dipendente in DipendentiFiltrati)
                            {

                                <tr @onclick="() => VaiADettaglioDipendente(dipendente.Codice)" style="cursor:pointer">
                                    <td>@dipendente.Codice</td>
                                    <td>@dipendente.Nome</td>
                                    <td>@dipendente.Cognome</td>
                                    <td>@dipendente.Email</td>
                                    <td>@dipendente.Qualifica</td>
                                    
                                    
                                    <td>@dipendente.Note</td>
                                    <td class="text-center"><button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => elimina(dipendente.Codice)" @onclick:stopPropagation="true"> <i class="bi bi-trash"></i> </button></td>

                           
                                </tr>
                                @if (!DipendentiFiltrati.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-3">Nessun cliente trovato</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    }
</div>


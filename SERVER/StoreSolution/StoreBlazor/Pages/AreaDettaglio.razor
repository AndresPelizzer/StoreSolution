@page "/aree/{id:int}"

@if (Id == 0)
{
    <div class="container mt-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Nuova Area</h5>
                <button class="btn btn-outline-secondary btn-sm" @onclick='() => Navigation!.NavigateTo("/aree")'>
                    <i class="bi bi-arrow-left"></i> Torna
                </button>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Codice</label>
                    <input class="form-control" @bind="NuovaArea.Codice" disabled />
                </div>
                <div class="mb-3">
                    <label class="form-label">Descrizione</label>
                    <input class="form-control" @bind="NuovaArea.Descrizione" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Note</label>
                    <input class="form-control" @bind="NuovaArea.Note" />
                </div>
            </div>
            <div class="card-footer">
                <button class="btn btn-success" @onclick="() => salvaArea(NuovaArea)">Salva</button>
            </div>
        </div>
    </div>
}

else
{
@if (AreaModificata == null)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="container mt-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Modifica Area</h5>
                <button class="btn btn-outline-secondary btn-sm" @onclick='() => Navigation!.NavigateTo("/aree")'>
                    <i class="bi bi-arrow-left"></i> Torna
                </button>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Codice</label>
                    <input class="form-control" @bind="AreaModificata!.Codice" disabled />
                </div>
                <div class="mb-3">
                    <label class="form-label">Descrizione</label>
                    <input class="form-control" @bind="AreaModificata!.Descrizione" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Note</label>
                    <input class="form-control" @bind="AreaModificata!.Note" />
                </div>
            </div>
            <div class="card-footer">
                <button class="btn btn-success" @onclick="() => modificaArea(AreaModificata!)">Salva</button>
            </div>
        </div>
    </div>
}
}





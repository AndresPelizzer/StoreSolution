@page "/dipendente/{id:int}/home"
@layout DipendenteLayout

<div class="container-fluid py-4">
    <div class="row g-4 justify-content-center">
        <div class="col-md-6 col-lg-4">
            <a href="calendario/@Id" class="text-decoration-none dashboard-card-link">
                <div class="card shadow-sm h-100 border-0 dashboard-card">
                    <div class="card-header bg-primary text-white py-3">
                        <h3 class="text-center mb-0 fs-5">
                            <i class="bi bi-calendar3 me-2"></i>CALENDARIO
                        </h3>
                    </div>
                    <div class="card-body text-center py-5 bg-light">
                        <i class="bi bi-calendar3 text-primary" style="font-size: 4.5rem;"></i>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .dashboard-card-link {
        display: block;
    }

    .dashboard-card {
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }

        .dashboard-card .card-header {
            border-bottom: none;
        }
</style>

@code {
    [Parameter]
    public int Id { get; set; }
}
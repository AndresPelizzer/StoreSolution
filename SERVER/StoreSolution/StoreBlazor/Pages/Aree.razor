@page "/aree"

<div class="container mt-4">
    @if (loading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Caricamento...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h4 class="mb-0 fw-bold text-secondary">
                        Aree Aziendali
                        <span class="badge bg-primary-subtle text-primary rounded-pill ms-2 fs-6">@aree?.Count</span>
                    </h4>
                    <button type="button" class="btn btn-primary btn-sm px-3 rounded-pill shadow-sm" @onclick="() => VaiArea(0)">
                        <i class="bi bi-plus-lg me-1"></i> Nuova Area
                    </button>
                </div>
            </div>

            <div class="card-body px-4 pb-4">
                <div class="table-responsive rounded-3 border">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-secondary">
                            <tr>
                                <th class="ps-3 text-center" style="width: 15%;">Codice</th>
                                <th style="width: 40%;">Descrizione</th>
                                <th style="width: 30%;">Note</th>
                                <th class="text-center pe-3" style="width: 15%;">Azioni</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (aree != null && aree.Any())
                            {
                                @foreach (var area in aree)
                                {
                                    <tr @onclick="() => VaiArea(area.Codice ?? 0)" style="cursor:pointer">
                                        <td class="ps-3 text-center fw-bold text-muted">#@area.Codice</td>
                                        <td class="fw-semibold text-dark">@area.Descrizione</td>
                                        <td class="text-muted">@(string.IsNullOrEmpty(area.Note) ? "-" : area.Note)</td>
                                        <td class="text-center pe-3">
                                            <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                    @onclick="() => elimina(area.Codice ?? 0)"
                                                    @onclick:stopPropagation="true">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-5">
                                        <i class="bi bi-diagram-3 fs-2 d-block mb-2 text-black-50"></i>
                                        Nessuna area configurata
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
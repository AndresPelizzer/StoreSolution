@page "/aree"


<div class="container mt-5">
    @if (loading == true)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">


                    <h5 class="mb-0">Aree <span class="badge bg-primary ms-1">@aree!.Count()</span></h5>

                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="()=> VaiArea(0)"> <i class="bi bi-plus-lg"></i>Nuova</button>
                </div>

            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered table-hover table-sm w-100">
                        <thead class="table-dark">
                            <tr>
                                <th>Codice</th>
                                <th>Descrizione</th>
                                <th>Note</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var area in aree!)
                            {
                                <tr @onclick="()=>VaiArea(area.Codice ?? 0)" style="cursor:pointer">
                                    <td>@area.Codice</td>
                                    <td>@area.Descrizione</td>
                                    <td>@area.Note</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    }
</div>





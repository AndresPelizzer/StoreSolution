@page "/clienti/{id:int}"



@if (Id == 0)
{

     
    <div class="container mt-5"></div>
    <div class="card">
        <div class="card-header">
            <h5>Aggiungi Nuovo Cliente</h5>
            <button class="btn-close"></button>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Codice</label>
                <input class="form-control" type="text" @bind="NuovoCliente.Codice" disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">Nome</label>
                <input class="form-control" type="text" @bind="NuovoCliente.Nome" />
            </div>
            <div class="mb-3">
                <label class="form-label">Cognome</label>
                <input class="form-control" type="text" @bind="NuovoCliente.Cognome" />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input class="form-control" type="text" @bind="NuovoCliente.Email" />
            </div>
            <div class="mb-3">
                <label class="form-label">Settore</label>
                <input class="form-control" type="text" @bind="NuovoCliente.Settore" />
            </div>
        </div>
        <div class="card-footer">

            
            <button class="btn btn-success" @onclick="() => salvaCliente(NuovoCliente)">Salva</button>
        </div>
    </div>

}
else
{
    
    <div class="container mt-5"></div>
    <div class="card">
        <div class="card-header">
            <h5>Dettaglio Cliente</h5>
            <button class="btn-close"></button>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Codice</label>
                <input class="form-control" type="text" @bind="ClienteModificato.Codice" disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">Nome</label>
                <input class="form-control" type="text" @bind="ClienteModificato.Nome" />
            </div>
            <div class="mb-3">
                <label class="form-label">Cognome</label>
                <input class="form-control" type="text" @bind="ClienteModificato.Cognome" />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input class="form-control" type="text" @bind="ClienteModificato.Email" />
            </div>
            <div class="mb-3">
                <label class="form-label">Settore</label>
                <input class="form-control" type="text" @bind="ClienteModificato.Settore" />
            </div>
        </div>
        <div class="card-footer">

            <button class="btn btn-outline-info" @onclick="() =>VaiARichieste(ClienteModificato.Codice) ">Mostra richieste</button>
            <button class="btn btn-success" @onclick="() => modificaCliente(ClienteModificato, ClienteModificato.Codice)">Salva</button>
        </div>
    </div>
}
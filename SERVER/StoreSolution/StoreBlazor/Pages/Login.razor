@page "/"
@layout LoginLayout

<div class="login-center">
    <div class="login-card">
        <div class="brand-logo">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h2 class="form-title">Store Blazor</h2>
        <p class="form-subtitle">Inserisci le tue credenziali per continuare</p>

        <div class="mb-3">
            <label class="form-label">Username</label>
            <input type="text" class="form-control" @bind="credenziali.Username" placeholder="es. mrossi" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" @bind="credenziali.Password" placeholder="••••••••" />
        </div>

        <button type="button" class="btn btn-primary w-100 mt-2" @onclick="login">
            Accedi
        </button>

        @if (errore != null)
        {
            <div class="alert-msg alert-error mt-3">
                <i class="bi bi-exclamation-circle"></i> @errore
            </div>
        }
        @if (successo != null)
        {
            <div class="alert-msg alert-success mt-3">
                <i class="bi bi-check-circle"></i> @successo
            </div>
        }
    </div>
</div>
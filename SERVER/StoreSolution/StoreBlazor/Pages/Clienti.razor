@page "/clienti"

<div class="container mt-5">

    @if (loading == true)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
             <div class="d-flex justify-content-between align-items-center mb-2">
               <h5 class="mb-0">Clienti <span class="badge bg-primary ms-1">@clienti.Count</span></h5>
              <button class="btn btn-primary btn-sm" @onclick="() => VaiADettaglioCliente(0)">
              <i class="bi bi-plus-lg"></i> Nuovo </button>
            </div>
            <input class="form-control form-control-sm" placeholder="🔍 Cerca cliente..." @bind="filtro" @bind:event="oninput" /></div>
           
            <div class="card-body">

          <div class="table-responsive">

            <table class="table table-borderless table-hover table-striped table-sm">
                <thead>
                    
                        <tr class="table-dark">
                                <th>Codice</th>
                                <th @onclick='() => Ordina("Nome")' style="cursor:pointer">Nome ↕</th>
                                <th @onclick='() => Ordina("Cognome")' style="cursor:pointer">Cognome ↕</th>
                                <th @onclick='() => Ordina("Email")' style="cursor:pointer">Email ↕</th>
                                <th @onclick='() => Ordina("Settore")' style="cursor:pointer">Settore ↕</th>
                                <th class="text-center">Azioni</th>
                        </tr>            
                    
                </thead>
                <tbody>

                      
                        @foreach (var cliente in ClientiFiltrati)
                    {
                                
                                <tr @onclick="() => VaiADettaglioCliente(cliente.Codice)" style="cursor:pointer">
                            <td>@cliente.Codice</td>
                            <td>@cliente.Nome</td>
                            <td>@cliente.Cognome</td>
                            <td>@cliente.Email</td>
                            <td>@cliente.Settore</td>
                                    <td class="text-center"><button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => elimina(cliente.Codice)" @onclick:stopPropagation="true"> <i class="bi bi-trash"></i> </button></td>

                           
                        </tr>
                                @if (!ClientiFiltrati.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-3">Nessun cliente trovato</td>
                                    </tr>
                                }
                    }
                </tbody>
            </table>
           </div>

        </div>
       </div>
    }
</div>

@page "/clienti"

<div class="container mt-4">

    @if (loading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Caricamento...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0 fw-bold text-secondary">
                        Clienti
                        <span class="badge bg-primary-subtle text-primary rounded-pill ms-2 fs-6">@clienti.Count</span>
                    </h4>
                    <button class="btn btn-primary btn-sm px-3 rounded-pill shadow-sm" @onclick="ApriNuovoCliente">
                        <i class="bi bi-plus-lg me-1"></i> Nuovo Cliente
                    </button>
                </div>

                <div class="input-group mb-2 shadow-sm rounded">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input class="form-control border-start-0 ps-0"
                           placeholder="Cerca cliente per nome o cognome..."
                           @bind="filtro"
                           @bind:event="oninput" />
                </div>
            </div>

            <div class="card-body px-4 pb-4">
                <div class="table-responsive rounded-3 border">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-secondary">
                            <tr>
                                <th class="ps-3">Codice</th>
                                <th @onclick='() => Ordina("Nome")' style="cursor:pointer" class="user-select-none">Nome <i class="bi bi-arrow-down-up ms-1 small text-muted"></i></th>
                                <th @onclick='() => Ordina("Cognome")' style="cursor:pointer" class="user-select-none">Cognome <i class="bi bi-arrow-down-up ms-1 small text-muted"></i></th>
                                <th @onclick='() => Ordina("Email")' style="cursor:pointer" class="user-select-none">Email <i class="bi bi-arrow-down-up ms-1 small text-muted"></i></th>
                                <th @onclick='() => Ordina("Settore")' style="cursor:pointer" class="user-select-none">Settore <i class="bi bi-arrow-down-up ms-1 small text-muted"></i></th>
                                <th class="text-center pe-3">Azioni</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ClientiFiltrati != null && ClientiFiltrati.Any())
                            {
                                @foreach (var cliente in ClientiFiltrati)
                                {
                                    <tr @onclick="() => VaiADettaglioCliente(cliente.Codice)" style="cursor:pointer">
                                        <td class="ps-3 fw-bold text-muted">#@cliente.Codice</td>
                                        <td>@cliente.Nome</td>
                                        <td>@cliente.Cognome</td>
                                        <td class="text-muted">@cliente.Email</td>
                                        <td>
                                            <span class="badge bg-light text-dark border px-2.5 py-1.5 rounded-pill">@cliente.Settore</span>
                                        </td>
                                        <td class="text-center pe-3">
                                            <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                    @onclick="() => elimina(cliente.Codice)"
                                                    @onclick:stopPropagation="true">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-5">
                                        <i class="bi bi-people fs-2 d-block mb-2 text-black-50"></i>
                                        Nessun cliente trovato
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

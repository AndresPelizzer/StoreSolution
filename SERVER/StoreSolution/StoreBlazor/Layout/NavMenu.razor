@* @using StoreBlazor.Services
@inject AuthState AuthState
@inject NavigationManager NavigationManager

<nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary px-3">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold text-uppercase tracking-wider" href="home">
            <i class="bi bi-shop text-primary me-2"></i>StoreBlazor
        </a>

        <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="@NavMenuCssClass navbar-collapse" id="navbarContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <NavLink class="nav-link d-flex align-items-center px-3" href="home" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door-fill me-2"></i> <span>Home</span>
                    </NavLink>
                </li>

                @if (AuthState.Ruolo == "Admin")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link d-flex align-items-center px-3" href="Aree">
                            <i class="bi bi-grid-3x3-gap-fill me-2"></i> <span>Aree</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link d-flex align-items-center px-3" href="clienti">
                            <i class="bi bi-people-fill me-2"></i> <span>Clienti</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link d-flex align-items-center px-3" href="dipendenti">
                            <i class="bi bi-person-badge-fill me-2"></i> <span>Dipendenti</span>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link d-flex align-items-center px-3" href="richieste">
                            <i class="bi bi-clipboard-check-fill me-2"></i> <span>Richieste</span>
                        </NavLink>
                    </li>
                }

                @if (AuthState.Ruolo == "Dipendente")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link d-flex align-items-center px-3" href="calendario">
                            <i class="bi bi-calendar3 me-2"></i> <span>Mio Calendario</span>
                        </NavLink>
                    </li>
                }
            </ul>

            <ul class="navbar-nav">
                <li class="nav-item">
                    @if (!string.IsNullOrEmpty(AuthState.Token))
                    {
                        <NavLink class="nav-link d-flex align-items-center px-3 text-danger" href="" @onclick="Logout">
                            <i class="bi bi-box-arrow-left me-2"></i> <span>Logout</span>
                        </NavLink>
                    }
                    else
                    {
                        <NavLink class="nav-link d-flex align-items-center px-3" href="">
                            <i class="bi bi-box-arrow-in-right me-2"></i> <span>Login</span>
                        </NavLink>
                    }
                </li>
            </ul>
        </div>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void Logout()
    {
        AuthState.Token = null;
        AuthState.Ruolo = null;
        AuthState.CodiceUtente = null;
        NavigationManager.NavigateTo("/");
    }
}
 *@
@page "/giocatori/{codice}"



<h3>Giocatore n. @codice</h3>




@if (giocatore == null)
{
    <em> attendere...  </em>
}
else
{
    
    <div class="card mt-3">
        <h5 class="card-title">Nome: @giocatore.name</h5>
        <h6 class="card-subtitle" mt-2> Username: @giocatore.username</h6>
        <h6 class="card-text">Email: @giocatore.email</h6>
    </div>

    <div class="mt-3">
        <a href="/giocatori" class="btn btn-secondary">Torna alla lista</a>
    </div>


}

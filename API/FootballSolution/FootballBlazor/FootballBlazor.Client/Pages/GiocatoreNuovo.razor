@page "/giocatore/nuovo"
@page "/giocatore/nuovo/{idSquadra:int}"
@rendermode InteractiveWebAssembly
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Aggiungi Nuovo Giocatore</h3>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3">
                    <label for="nome" class="form-label">Nome</label>
                    <input type="text" id="nome" class="form-control" @bind="nuovoGiocatore.Nome" />
                </div>

                <div class="col-md-3">
                    <label for="cognome" class="form-label">Cognome</label>
                    <input type="text" id="cognome" class="form-control" @bind="nuovoGiocatore.Cognome" />
                </div>

                <div class="col-md-3">
                    <label for="ruolo" class="form-label">Ruolo</label>
                    <input type="text" id="ruolo" class="form-control" @bind="nuovoGiocatore.Ruolo" />
                </div>

                <div class="col-md-3">
                    <label for="idSquadra" class="form-label">ID Squadra</label>
                    
                    <input type="number" id="idSquadra" class="form-control"
                           @bind="nuovoGiocatore.Idsquadra" disabled="@IdSquadra.HasValue" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-success" @onclick="SalvaGiocatore">Salva Giocatore</button>
                <button type="button" class="btn btn-secondary" @onclick="TornaIndietro">Indietro</button>
            </div>
        </div>
    </div>
</div>

@code {
    
    [Parameter]
    public int? IdSquadra { get; set; }

    private Giocatori nuovoGiocatore = new Giocatori();

    protected override void OnInitialized()
    {
        if (IdSquadra.HasValue)
        {
            nuovoGiocatore.Idsquadra = IdSquadra.Value;
        }
    }

    private async Task SalvaGiocatore()
    {
        await Http.PostAsJsonAsync("api/giocatori", nuovoGiocatore);

        if (IdSquadra.HasValue)
        {
            Navigation.NavigateTo($"/squadra/{IdSquadra.Value}");
        }
        else
        {
            Navigation.NavigateTo("/squadre");
        }
    }

    private void TornaIndietro()
    {
        if (IdSquadra.HasValue)
        {
            Navigation.NavigateTo($"/squadra/{IdSquadra.Value}");
        }
        else
        {
            Navigation.NavigateTo("/squadre");
        }
    }
}
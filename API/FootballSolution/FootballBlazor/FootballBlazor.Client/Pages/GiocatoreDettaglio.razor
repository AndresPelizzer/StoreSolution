@using FootballBlazor.Shared.Models;


@page "/giocatore/{id:int}"
@rendermode InteractiveWebAssembly

<div class="container mt-4">

    @if (giocatore == null)
    {
        <div class="d-flex align-items-center justify-content-center py-5">
            <div class="spinner-border text-primary me-2" role="status"></div>
            <span>Caricamento giocatore...</span>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                
                <h3 class="mb-0">Dettaglio Giocatore</h3>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label class="form-label">ID</label>
                        <input type="text" class="form-control" value="@giocatore.Idgiocatore" disabled />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Nome</label>
                        <input type="text" class="form-control" @bind="giocatore.Nome" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Cognome</label>
                        <input type="text" class="form-control" @bind="giocatore.Cognome" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Ruolo</label>
                        <input type="text" class="form-control" @bind="giocatore.Ruolo" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">ID Squadra</label>
                        <input type="number" class="form-control" @bind="giocatore.Idsquadra" />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-success" @onclick="SalvaModifica">Salva Modifiche</button>
                    <button class="btn btn-secondary" @onclick="TornaAllaSquadra">Torna alla Squadra</button>
                </div>
            </div>
        </div>
    }
</div>


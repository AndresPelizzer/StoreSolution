@page "/squadra/nuova"
@rendermode InteractiveWebAssembly
@using FootballBlazor.Client.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Aggiungi Nuova Squadra</h3>
        </div>
        <div class="card-body">
            

                <div class="mb-3">
                    <label for="nome" class="form-label">Nome Squadra</label>
                    <input type="text" id="nome" class="form-control" @bind="nuovaSquadra.NomeSquadra" />
                </div>

                <div class="mb-3">
                    <label for="citta" class="form-label">Città</label>
                    <input type="text" id="citta" class="form-control" @bind="nuovaSquadra.Citta" />
                </div>

                <div class="mb-3">
                    <label for="allenatore" class="form-label">Allenatore</label>
                    <input type="text" id="allenatore" class="form-control" @bind="nuovaSquadra.Allenatore" />
                </div>

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-success" @onclick="SalvaSquadra" >Salva Squadra</button>
                    <button type="button" class="btn btn-secondary" @onclick="TornaAllElenco">Torna alla lista</button>
                </div>
           
        </div>
    </div>
</div>

@code {
    
    private Shared.Models.Squadre nuovaSquadra = new Shared.Models.Squadre();

    private async Task SalvaSquadra()
    {
        await Http.PostAsJsonAsync("api/squadre", nuovaSquadra);

        Navigation.NavigateTo("/squadre");
    }

    private void TornaAllElenco()
    {
        Navigation.NavigateTo("/squadre");
    }
}
